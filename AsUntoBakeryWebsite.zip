<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>As Unto Bakery</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Lora:wght@400;500&family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">

<link rel="stylesheet" href="css/style.css">

</head>

<body>

<header>

    <img src="images/logo.png" alt="As Unto Bakery Logo" class="logo">

    <nav>

        <a href="index.html">Home</a>

        <a href="about.html">About</a>

        <a href="menu.html">Menu</a>

        <a href="gallery.html">Gallery</a>

        <a href="contact.html">Contact</a>

        <a href="order.html" class="order-btn">

            Request an Order

        </a>

    </nav>

</header>

<section class="hero">

    <div class="hero-box">

        <p class="welcome">
            Welcome to
        </p>

        <h1>As Unto Bakery</h1>

        <p class="quote">

            Treats crafted with care,
            made as unto the Lord.

        </p>

        <div class="buttons">

            <a href="order.html" class="primary">

                Request an Order

            </a>

            <a href="menu.html" class="secondary">

                View Menu

            </a>

        </div>

    </div>

</section>

</body>

</html>
