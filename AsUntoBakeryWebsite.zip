├── css/
│   └── /* ===========================
   AS UNTO BAKERY
   Version 1.0
=========================== */

:root{

--dusty:#D19A90;
--butter:#EBD6A9;
--sage:#9D998A;
--cloud:#ABB4B3;
--taupe:#BCAD99;
--cocoa:#594E44;
--white:#FFFDFB;

}

*{

margin:0;
padding:0;
box-sizing:border-box;

}

html{

scroll-behavior:smooth;

}

body{

background:var(--white);

font-family:'Lora',serif;

color:var(--cocoa);

}

header{

display:flex;

justify-content:space-between;

align-items:center;

padding:20px 8%;

background:white;

position:sticky;

top:0;

z-index:1000;

box-shadow:0 3px 12px rgba(0,0,0,.05);

}

.logo{

height:95px;

}

nav{

display:flex;

align-items:center;

gap:30px;

font-family:'Poppins',sans-serif;

}

nav a{

text-decoration:none;

color:var(--cocoa);

font-weight:500;

transition:.3s;

}

nav a:hover{

color:var(--dusty);

}

.order-btn{

background:var(--dusty);

color:white;

padding:14px 24px;

border-radius:40px;

}

.order-btn:hover{

background:var(--cocoa);

color:white;

}

.hero{

padding:120px 20px;

background:linear-gradient(
rgba(255,253,251,.92),
rgba(255,253,251,.92)
);

text-align:center;

}

.hero-box{

max-width:750px;

margin:auto;

}

.welcome{

letter-spacing:4px;

font-family:'Poppins',sans-serif;

text-transform:uppercase;

color:var(--sage);

margin-bottom:15px;

}

.hero h1{

font-family:'Playfair Display',serif;

font-size:64px;

margin-bottom:20px;

}

.quote{

font-size:24px;

margin-bottom:45px;

}

.buttons{

display:flex;

justify-content:center;

gap:20px;

flex-wrap:wrap;

}

.primary{

background:var(--dusty);

color:white;

padding:16px 30px;

border-radius:50px;

text-decoration:none;

font-family:'Poppins',sans-serif;

font-weight:600;

}

.secondary{

background:var(--butter);

color:var(--cocoa);

padding:16px 30px;

border-radius:50px;

text-decoration:none;

font-family:'Poppins',sans-serif;

font-weight:600;

}
