├── css/
│   └── style.css/* ===========
   AS UNTO BAKERY
   Main Stylesheet
=========== */

:root{

--dusty-rose:#D19A90;

--butter-cream:#EBD6A9;

--sage-green:#9D998A;

--cloud-blue:#ABB4B3;

--warm-taupe:#BCAD99;

--cocoa:#594E44;

--white:#FFFDFB;

}

*{

margin:0;

padding:0;

box-sizing:border-box;

}

body{

font-family:'Lora', serif;

background:var(--white);

color:var(--cocoa);

line-height:1.7;

}

h1,h2,h3,h4{

font-family:'Playfair Display', serif;

}

a{

text-decoration:none;

color:inherit;

}

img{

max-width:100%;

display:block;

}

section{

padding:80px 8%;

}
